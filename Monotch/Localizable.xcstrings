    "Version %@ — everything the notch can do, and what to check when it doesn't." : {
      "comment" : "A footnote at the bottom of the help view.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الإصدار %@ — كل ما يمكن أن يفعله الشق، وما يجب التحقق منه عندما لا يعمل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Version %@ — alles, was die Notch kann, und was zu prüfen ist, wenn nicht."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Έκδοση %@ — όλα όσα μπορεί να κάνει η εγκοπή, και τι να ελέγξετε όταν δεν λειτουργεί."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Versión %@: todo lo que la muesca puede hacer y qué revisar cuando no lo hace."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نسخه %@ — همه کارهایی که ناچ می‌تواند انجام دهد و در صورت مشکل چه چیزی را بررسی کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Version %@ — tout ce que l'encoche peut faire, et que vérifier si ce n'est pas le cas."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "संस्करण %@ — नॉच जो कुछ कर सकता है, और जब न करे तो क्या जाँचें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バージョン %@ — ノッチができることすべてと、うまくいかないときの確認事項。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "버전 %@ — 노치가 할 수 있는 모든 것과 작동하지 않을 때 확인할 사항."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Версия %@ — всё, что умеет вырез, и что проверить, если что-то не работает."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sürüm %@ — çentiğin yapabileceği her şey ve çalışmadığında kontrol edilmesi gerekenler."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Версія %@ — усе, що вміє виїмка, і що перевірити, якщо щось не працює."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
