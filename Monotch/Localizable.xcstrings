    "History fills as you copy. Clearing it from the Edit menu is permanent." : {
      "comment" : "A description of how to clear the clipboard history.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمتلئ السجل كلما نسخت. مسحه من قائمة تحرير أمر دائم."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Verlauf füllt sich beim Kopieren. Das Löschen über das Bearbeiten-Menü ist endgültig."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το ιστορικό γεμίζει καθώς αντιγράφετε. Η εκκαθάρισή του από το μενού Επεξεργασία είναι μόνιμη."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El historial se llena a medida que copias. Borrarlo desde el menú Edición es permanente."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "با کپی کردن، تاریخچه پر می‌شود. پاک کردن آن از منوی Edit دائمی است."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'historique se remplit à chaque copie. Le vider depuis le menu Édition est définitif."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जैसे-जैसे आप कॉपी करते हैं, इतिहास भरता जाता है। एडिट मेनू से साफ़ करना स्थायी है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コピーするたびに履歴が増えます。編集メニューからの消去は元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "복사할 때마다 기록이 채워집니다. 편집 메뉴에서 지우면 영구적으로 삭제됩니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "История заполняется по мере копирования. Очистка через меню «Правка» необратима."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kopyaladıkça geçmiş dolar. Düzen menüsünden temizlemek kalıcıdır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Історія заповнюється під час копіювання. Очищення через меню «Редагувати» незворотне."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "复制内容会自动填充历史记录。从编辑菜单清除后不可恢复。"
          }
        }
      }
    },
