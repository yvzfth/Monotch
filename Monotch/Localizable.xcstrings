    "A reference for what the notch can do and how to resolve common issues." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مرجع لما يمكن أن يفعله الشق وكيفية حل المشكلات الشائعة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Nachschlagewerk dafür, was die Notch kann und wie man häufige Probleme löst."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ένας οδηγός για όσα μπορεί να κάνει η εγκοπή και πώς να λύσετε συνήθη προβλήματα."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una referencia sobre lo que puede hacer la muesca y cómo resolver problemas comunes."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مرجعی برای کارهایی که ناچ می‌تواند انجام دهد و نحوه حل مشکلات رایج."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une référence sur ce que l'encoche peut faire et comment résoudre les problèmes courants."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "नॉच क्या कर सकता है और सामान्य समस्याओं को कैसे हल करें, इसकी एक संदर्भ सूची।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ノッチの機能と、よくある問題の解決方法についての参考資料です。"
          }
