    "CPU, RAM, Storage, Fans, and Sensors can be removed or added back from here." : {
      "comment" : "A description of the system cards section.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكن إزالة أو إعادة إضافة المعالج والذاكرة والتخزين والمراوح وأجهزة الاستشعار من هنا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CPU, RAM, Speicher, Lüfter und Sensoren können hier entfernt oder wieder hinzugefügt werden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η CPU, η RAM, ο αποθηκευτικός χώρος, οι ανεμιστήρες και οι αισθητήρες μπορούν να αφαιρεθούν ή να προστεθούν ξανά από εδώ."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La CPU, la RAM, el almacenamiento, los ventiladores y los sensores se pueden quitar o volver a añadir aquí."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "پردازنده، رم، فضای ذخیره‌سازی، فن‌ها و سنسورها را می‌توانید از اینجا حذف یا دوباره اضافه کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le CPU, la RAM, le stockage, les ventilateurs et les capteurs peuvent être retirés ou réajoutés ici."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CPU, RAM, स्टोरेज, फ़ैन और सेंसर यहाँ से हटाए या फिर से जोड़े जा सकते हैं।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CPU、RAM、ストレージ、ファン、センサーはここから削除したり再表示したりできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CPU, RAM, 저장 용량, 팬, 센서를 여기서 제거하거나 다시 추가할 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ЦП, ОЗУ, накопитель, вентиляторы и датчики можно убрать или вернуть здесь."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CPU, RAM, Depolama, Fanlar ve Sensörler buradan kaldırılabilir veya yeniden eklenebilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ЦП, ОЗП, накопичувач, вентилятори й датчики можна прибрати або повернути тут."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "可以在此处移除或重新添加 CPU、内存、存储、风扇和传感器。"
          }
        }
      }
    },
